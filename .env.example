# Backend API Configuration
# Use this to configure where the dashboard fetches metrics from

# For local development (backend running on localhost:3000)
# VITE_API_BASE_URL=http://localhost:3000

# For ngrok tunnel (replace with your actual ngrok URL)
# VITE_API_BASE_URL=https://xxxx-xx-xxx-xx-xx.ngrok.io

# For Replit (original deployment)
# VITE_API_BASE_URL=https://forge-backend--xavierhofer.replit.app

# Default fallback
VITE_API_BASE_URL=http://localhost:3000
